# Auth.js v5
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated list of e-mails that get auto-provisioned as admin on first login
ADMIN_EMAILS=vbalko@gmail.com

# SQLite path (in Coolify map this to a persistent volume, e.g. /app/data/svj.db)
DB_PATH=./data/svj.db

# Google Drive backup — OAuth pod osobním účtem (vbalko@gmail.com).
# 1) V GCP Console vytvořit OAuth client typu "Desktop app" s redirect
#    URI http://localhost:8765/callback.
# 2) Lokálně spustit `pnpm auth-gdrive` → autorizovat v browseru → získat
#    refresh_token a vložit ho jako GDRIVE_REFRESH_TOKEN.
# 3) GDRIVE_FOLDER_ID = ID složky v personal Drive, do které se zálohuje.
GDRIVE_OAUTH_CLIENT_ID=
GDRIVE_OAUTH_CLIENT_SECRET=
GDRIVE_REFRESH_TOKEN=
GDRIVE_FOLDER_ID=

# Optional backup encryption passphrase. When set + enabled in backup settings,
# nightly DB backups are AES-256-GCM encrypted (key derived via scrypt).
BACKUP_PASSPHRASE=
