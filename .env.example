# Auth.js v5
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated list of e-mails that get auto-provisioned as admin on first login
ADMIN_EMAILS=vbalko@gmail.com

# SQLite path (in Coolify map this to a persistent volume, e.g. /app/data/svj.db)
DB_PATH=./data/svj.db

# Google Drive backup (optional — set GDRIVE_SA_CONFIGURED in backup_settings via UI)
# Service account JSON pasted inline (single line, escaped) — leave empty until configured
GDRIVE_SA_KEY_JSON=
GDRIVE_FOLDER_ID=

# Optional backup encryption passphrase. When set + enabled in backup settings,
# nightly DB backups are AES-256-GCM encrypted (key derived via scrypt).
BACKUP_PASSPHRASE=
